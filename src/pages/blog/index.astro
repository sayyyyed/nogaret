---
import { getCollection } from 'astro:content';
import ContentCard from '../../components/content/ContentCard.astro';
import SectionHero from '../../components/content/SectionHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectionPath } from '../../lib/content/routes';
import { isPublished, sortByDateDescending } from '../../lib/content/sort';

const entries = sortByDateDescending((await getCollection('blog')).filter(isPublished));
---

<BaseLayout title="Blog" description="Long-form technical writing and engineering essays.">
  <SectionHero title="Blog" description="Long-form technical writing across software engineering, web development, AI, and education systems." />
  <section class="grid-list">
    {entries.map((entry) => (
      <ContentCard title={entry.data.title} description={entry.data.description} href={collectionPath('blog', entry.id)} tags={entry.data.tags} />
    ))}
  </section>
</BaseLayout>
