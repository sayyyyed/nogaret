---
import { getCollection } from 'astro:content';
import ContentCard from '../../components/content/ContentCard.astro';
import SectionHero from '../../components/content/SectionHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectionPath } from '../../lib/content/routes';
import { isPublished, sortByDateDescending } from '../../lib/content/sort';

const entries = sortByDateDescending((await getCollection('tutorials')).filter(isPublished));
---

<BaseLayout title="Tutorials" description="Practical learning paths and implementation guides.">
  <SectionHero title="Tutorials" description="Step-by-step guides with prerequisites, outcomes, and durable implementation notes." />
  <section class="grid-list">
    {entries.map((entry) => (
      <ContentCard title={entry.data.title} description={entry.data.description} href={collectionPath('tutorials', entry.id)} tags={entry.data.tags} />
    ))}
  </section>
</BaseLayout>
