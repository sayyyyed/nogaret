</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const experienceTabs = Array.from(document.querySelectorAll('[data-experience-tab]'));
  const experiencePanels = Array.from(document.querySelectorAll('[data-experience-panel]'));
  const experienceScrollAreas = Array.from(document.querySelectorAll('[data-experience-scroll]'));
  const accordionItems = Array.from(document.querySelectorAll('[data-accordion-item]'));
  const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

  /* ── API Frankfurter Fetch ── */
  async function fetchRatesAndUpdate() {
    try {
      const symbols = ['USD', 'SGD', 'HKD', 'JPY', 'EUR', 'GBP', 'AUD'];
      const dateObj = new Date();
      dateObj.setDate(dateObj.getDate() - 7);
      const startDate = dateObj.toISOString().split('T')[0];
      
      const res = await fetch(`https://api.frankfurter.dev/v1/${startDate}..?symbols=IDR,USD,SGD,HKD,JPY,GBP,AUD`);
      const data = await res.json();
      
      const dates = Object.keys(data.rates).sort();
      if (dates.length < 2) return;
      
      const latestDate = dates[dates.length - 1];
      const prevDate = dates[dates.length - 2];
      
      const latestRates = data.rates[latestDate];
      const prevRates = data.rates[prevDate];
      latestRates['EUR'] = 1;
      prevRates['EUR'] = 1;
      
      const items = [...symbols, ...symbols, ...symbols];
      const html = items.map(sym => {
        const rateLatest = latestRates.IDR / latestRates[sym];
        const ratePrev = prevRates.IDR / prevRates[sym];
        const diff = rateLatest - ratePrev;
        const up = diff >= 0;
        return `<span class="marquee-item">
          <span class="currency-pair">${sym}/IDR</span>
          <span class="currency-rate">${rateLatest.toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
          <span class="currency-diff ${up ? 'diff-up' : 'diff-down'}">
            ${up ? '↑' : '↓'} ${Math.abs(diff).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
          </span>
        </span>`;
      }).join('');

      document.querySelectorAll('.marquee-content').forEach(el => {
        el.innerHTML = html;
      });
    } catch (err) {
      console.error('Frankfurter API fetch failed:', err);
    }
  }

  fetchRatesAndUpdate();

  /* ── Marquee GSAP animation ── */
  if (!motionQuery.matches) {
    const track = document.querySelector('[data-marquee-track]');
    if (track) {
      const contents = track.querySelectorAll('.marquee-content');
      if (contents.length >= 2) {
        gsap.set(contents, { xPercent: 0 });

        const tl = gsap.timeline({ repeat: -1 });
        tl.to(contents, {
          xPercent: -100,
          duration: 40,
          ease: 'none',
        });

        // ScrollTrigger: speed up marquee on scroll
        ScrollTrigger.create({
          trigger: track,
          start: 'top bottom',
          end: 'bottom top',
          onUpdate: (self) => {
            const velocity = Math.abs(self.getVelocity()) / 1000;
            const speedMultiplier = 1 + Math.min(velocity * 0.5, 3);
            tl.timeScale(speedMultiplier);
          },
          onLeave: () => { tl.timeScale(1); },
          onLeaveBack: () => { tl.timeScale(1); },
        });

        track.addEventListener('mouseenter', () => tl.pause());
        track.addEventListener('mouseleave', () => tl.play());
      }
    }
  }

  /* ── Bento Box Hover ── */
  const bentoNotes = document.querySelectorAll('.home-note');
  bentoNotes.forEach(note => {
    const arrow = note.querySelector('.bento-arrow');
    const svg = arrow?.querySelector('svg');
    if (!arrow || !svg) return;
    
    const tlHover = gsap.timeline({ paused: true, defaults: { ease: 'back.out(1.7)', duration: 0.4 } });
    
    tlHover.to(arrow, { scale: 1, autoAlpha: 1, backgroundColor: 'var(--primary)', x: 0, y: 0 })
           .to(svg, { x: 2, y: -2, color: '#23251d' }, "<0.1");
           
    gsap.set(arrow, { scale: 0.8, autoAlpha: 0, x: -15, y: 15 });

    note.addEventListener('mouseenter', () => tlHover.play());
    note.addEventListener('mouseleave', () => tlHover.reverse());
    note.addEventListener('focus', () => tlHover.play());
    note.addEventListener('blur', () => tlHover.reverse());
  });

  /* ── Contact section reveal ── */
  if (!motionQuery.matches) {
    const contactHero = document.querySelector('.contact-hero');
    if (contactHero) {
      gsap.from(contactHero.querySelector('.contact-hero-header'), {
        scrollTrigger: {
          trigger: contactHero,
          start: 'top 85%',
          once: true,
        },
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: 'power4.out',
      });

      gsap.from(contactHero.querySelector('[data-contact-composer]'), {
        scrollTrigger: {
          trigger: contactHero,
          start: 'top 75%',
          once: true,
        },
        y: 60,
        opacity: 0,
        duration: 0.9,
        delay: 0.15,
        ease: 'power4.out',
      });
    }
  }

  /* ── Experience tabs ── */
  const activateExperience = (activeTab) => {
    const activeId = activeTab.getAttribute('data-experience-tab');

    experienceTabs.forEach((tab) => {
      const selected = tab === activeTab;
      tab.setAttribute('aria-selected', String(selected));
      tab.setAttribute('tabindex', selected ? '0' : '-1');
    });

    experiencePanels.forEach((panel) => {
      panel.hidden = panel.getAttribute('data-experience-panel') !== activeId;
    });
  };

  experienceTabs.forEach((tab, index) => {
    tab.addEventListener('click', () => activateExperience(tab));
    tab.addEventListener('keydown', (event) => {
      if (!['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft'].includes(event.key)) return;

      event.preventDefault();
      const direction = event.key === 'ArrowDown' || event.key === 'ArrowRight' ? 1 : -1;
      const nextIndex = (index + direction + experienceTabs.length) % experienceTabs.length;
      const nextTab = experienceTabs[nextIndex];

      if (nextTab instanceof HTMLElement) {
        nextTab.focus();
        activateExperience(nextTab);
      }
    });
  });

  const updateExperienceScrollState = (scrollArea) => {
    if (!(scrollArea instanceof HTMLElement)) return;

    const wrapper = scrollArea.closest('[data-experience-scroll-wrap]');
    if (!(wrapper instanceof HTMLElement)) return;

    const maxScroll = scrollArea.scrollHeight - scrollArea.clientHeight;
    const hasOverflow = maxScroll > 1;
    const isAtTop = scrollArea.scrollTop <= 1;
    const isAtBottom = scrollArea.scrollTop >= maxScroll - 1;

    wrapper.dataset.scrollState = !hasOverflow ? 'none' : isAtTop ? 'top' : isAtBottom ? 'bottom' : 'middle';
  };

  experienceScrollAreas.forEach((scrollArea) => {
    if (!(scrollArea instanceof HTMLElement)) return;

    updateExperienceScrollState(scrollArea);
    scrollArea.addEventListener('scroll', () => updateExperienceScrollState(scrollArea), { passive: true });
    window.addEventListener('resize', () => updateExperienceScrollState(scrollArea));
  });

  /* ── Accordion ── */
  const setAccordionItem = (item, open) => {
    const trigger = item.querySelector('[data-accordion-trigger]');
    const panel = item.querySelector('[data-accordion-panel]');

    if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

    trigger.setAttribute('aria-expanded', String(open));
    item.setAttribute('data-open', String(open));

    if (motionQuery.matches) {
      panel.style.height = open ? 'auto' : '0px';
      panel.style.opacity = open ? '1' : '0';
      return;
    }

    gsap.killTweensOf(panel);

    if (open) {
      panel.style.height = 'auto';
      const targetHeight = panel.offsetHeight;
      panel.style.height = '0px';
      gsap.to(panel, {
        duration: 0.44,
        ease: 'power4.out',
        height: targetHeight,
        opacity: 1,
        onComplete: () => {
          panel.style.height = 'auto';
        },
      });
      return;
    }

    gsap.to(panel, {
      duration: 0.32,
      ease: 'power3.inOut',
      height: 0,
      opacity: 0,
    });
  };

  accordionItems.forEach((item, index) => {
    setAccordionItem(item, index === 0);

    const trigger = item.querySelector('[data-accordion-trigger]');
    if (!(trigger instanceof HTMLButtonElement)) return;

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      accordionItems.forEach((accordionItem) => setAccordionItem(accordionItem, accordionItem === item ? !isOpen : false));
    });
  });
</script>

