---
import { getCollection } from 'astro:content';
import ContentCard from '../../components/content/ContentCard.astro';
import SectionHero from '../../components/content/SectionHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectionPath } from '../../lib/content/routes';
import { isPublished, sortByDateDescending } from '../../lib/content/sort';

const entries = sortByDateDescending((await getCollection('changelog')).filter(isPublished));
---

<BaseLayout title="Changelog">
  <SectionHero title="Changelog" description="A public record of site architecture, content, and feature changes." />
  <section class="grid-list">
    {entries.map((entry) => (
      <ContentCard title={entry.data.title} description={entry.data.description} href={collectionPath('changelog', entry.id)} tags={entry.data.tags} />
    ))}
  </section>
</BaseLayout>
