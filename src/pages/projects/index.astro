---
import { getCollection } from 'astro:content';
import ContentCard from '../../components/content/ContentCard.astro';
import SectionHero from '../../components/content/SectionHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectionPath } from '../../lib/content/routes';
import { isPublished, sortByDateDescending } from '../../lib/content/sort';

const entries = sortByDateDescending((await getCollection('projects')).filter(isPublished));
---

<BaseLayout title="Projects" description="Content-managed portfolio projects.">
  <SectionHero title="Projects" description="Portfolio entries managed as content with status, stack, repositories, demos, screenshots, and related writing." />
  <section class="grid-list">
    {entries.map((entry) => (
      <ContentCard eyebrow={entry.data.status} title={entry.data.title} description={entry.data.description} href={collectionPath('projects', entry.id)} tags={entry.data.techStack} />
    ))}
  </section>
</BaseLayout>
