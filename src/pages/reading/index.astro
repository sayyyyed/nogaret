---
import ContentCard from '../../components/content/ContentCard.astro';
import SectionHero from '../../components/content/SectionHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollectionIfNotEmpty } from '../../lib/content/collections';
import { collectionPath } from '../../lib/content/routes';
import { isPublished, sortByDateDescending } from '../../lib/content/sort';

const entries = sortByDateDescending((await getCollectionIfNotEmpty('reading')).filter(isPublished));
---

<BaseLayout title="Reading List" description="Reading notes and summaries.">
  <SectionHero title="Reading List" description="Reading notes, summaries, source reflections, and references for future articles." />
  <section class="grid-list">
    {entries.map((entry) => (
      <ContentCard title={entry.data.title} description={entry.data.description} href={collectionPath('reading', entry.id)} tags={entry.data.tags} />
    ))}
  </section>
</BaseLayout>
