---
import { primaryNavigation, secondaryNavigation, site } from '../data/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.name, description = site.description } = Astro.props;
const pageTitle = title === site.name ? site.name : `${title} | ${site.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="nav-shell" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="Home">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="img">
              <path d="M9 28c0-9 7-16 17-16 8 0 14 5 14 13 0 8-6 13-15 13H12c-2 0-3-1-3-3v-7Z" fill="#f7a501" />
              <path d="M16 15 12 8m10 4-1-8m9 10 5-7" stroke="#23251d" stroke-linecap="round" stroke-width="3" />
              <path d="M12 32c4-7 6-9 8-5 2 1 7-5 8-3 1 1-1 4-1 5 4-2 7-6 12-9" fill="none" stroke="#23251d" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" />
            </svg>
          </span>
          {site.name && <span>{site.name}</span>}
        </a>
        <div class="nav-links desktop-nav">
          {primaryNavigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
        <div class="nav-actions">
          <a class="nav-cta" href="/contact/">Get started</a>
        </div>
        <button class="nav-toggle mobile-nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" data-nav-toggle>
          <span data-line-top></span>
          <span data-line-bottom></span>
        </button>
      </nav>
      <div id="mobile-menu" class="mobile-menu" hidden data-mobile-menu>
        <nav aria-label="Mobile navigation">
          {primaryNavigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{site.name}</strong>
        <p>{site.description}</p>
      </div>
      <nav class="footer-links" aria-label="Secondary navigation">
        {secondaryNavigation.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </footer>
    <script>
      import { gsap } from 'gsap';

      const navToggle = document.querySelector('[data-nav-toggle]');
      const mobileMenu = document.querySelector('[data-mobile-menu]');
      const lineTop = document.querySelector('[data-line-top]');
      const lineBottom = document.querySelector('[data-line-bottom]');
      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

      if (navToggle instanceof HTMLButtonElement && mobileMenu instanceof HTMLElement && lineTop && lineBottom) {
        let isOpen = false;
        const menuLinks = mobileMenu.querySelectorAll('a');

        gsap.set(mobileMenu, {
          autoAlpha: 0,
          clipPath: 'inset(0 0 100% 0)',
          y: -8,
        });

        const openMenu = () => {
          isOpen = true;
          mobileMenu.hidden = false;
          navToggle.classList.add('is-open');
          navToggle.setAttribute('aria-expanded', 'true');
          navToggle.setAttribute('aria-label', 'Close menu');

          if (motionQuery.matches) {
            gsap.set(mobileMenu, { autoAlpha: 1, clipPath: 'inset(0 0 0% 0)', y: 0 });
            gsap.set(lineTop, { y: 0, rotate: 45 });
            gsap.set(lineBottom, { y: 0, rotate: -45 });
            return;
          }

          gsap.killTweensOf([mobileMenu, lineTop, lineBottom, menuLinks]);
          gsap.timeline({ defaults: { ease: 'power4.out' } })
            .to(lineTop, { duration: 0.45, y: 0, rotate: 45 }, 0)
            .to(lineBottom, { duration: 0.45, y: 0, rotate: -45 }, 0)
            .to(mobileMenu, { duration: 0.5, autoAlpha: 1, clipPath: 'inset(0 0 0% 0)', y: 0 }, 0)
            .fromTo(menuLinks, { opacity: 0, y: -6 }, { duration: 0.35, opacity: 1, stagger: 0.035, y: 0 }, 0.12);
        };

        const closeMenu = () => {
          isOpen = false;
          navToggle.classList.remove('is-open');
          navToggle.setAttribute('aria-expanded', 'false');
          navToggle.setAttribute('aria-label', 'Open menu');

          if (motionQuery.matches) {
            gsap.set(mobileMenu, { autoAlpha: 0, clipPath: 'inset(0 0 100% 0)', y: -8 });
            gsap.set(lineTop, { y: -4, rotate: 0 });
            gsap.set(lineBottom, { y: 4, rotate: 0 });
            mobileMenu.hidden = true;
            return;
          }

          gsap.killTweensOf([mobileMenu, lineTop, lineBottom, menuLinks]);
          gsap.timeline({
            defaults: { ease: 'power4.inOut' },
            onComplete: () => {
              mobileMenu.hidden = true;
            },
          })
            .to(menuLinks, { duration: 0.18, opacity: 0, stagger: 0.015, y: -4 }, 0)
            .to(mobileMenu, { duration: 0.36, autoAlpha: 0, clipPath: 'inset(0 0 100% 0)', y: -8 }, 0.05)
            .to(lineTop, { duration: 0.42, y: -4, rotate: 0 }, 0)
            .to(lineBottom, { duration: 0.42, y: 4, rotate: 0 }, 0);
        };

        navToggle.addEventListener('click', () => {
          if (isOpen) {
            closeMenu();
          } else {
            openMenu();
          }
        });

        menuLinks.forEach((link) => {
          link.addEventListener('click', closeMenu);
        });

        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && isOpen) {
            closeMenu();
            navToggle.focus();
          }
        });
      }
    </script>
  </body>
</html>
